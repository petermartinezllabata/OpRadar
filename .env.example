# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Notion integration token — get from notion.so/profile/integrations
NOTION_TOKEN=secret_your-token-here

# Notion database ID — the long string in your database URL
# e.g. https://notion.so/yourworkspace/792c6c4ae8b448f79441bc493af9b94f?v=...
#                                      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_DATABASE_ID=your-database-id-here
